# Secrets via Bitwarden Secrets Manager (project: personal).
# Human-dev convenience; scripts/agents should prefer: bws run -- <cmd>
export BWS_ACCESS_TOKEN="$(cat "$HOME/.config/bitwarden-secrets/personal.token")"
eval "$(bws-env "$(cat "$HOME/.config/bitwarden-secrets/personal.project-id")")"
export OPENROUTER_API_KEY="$OPENROUTER_API_KEY_BEEPER"
